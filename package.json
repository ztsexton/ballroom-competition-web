{
  "name": "ballroom-competition-web-root",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "integration-tests",
    "e2e-tests"
  ],
  "scripts": {
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "npm run test --workspace backend && npm run test --workspace frontend",
    "test:integration": "npm run test --workspace integration-tests",
    "test:e2e:local": "npm run test --workspace e2e-tests",
    "test:e2e:open": "npm run test:open --workspace e2e-tests"
  }
}
