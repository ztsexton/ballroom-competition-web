# Dependencies
node_modules/
**/node_modules/

# Build outputs (we build inside Docker)
**/dist/
**/build/

# Development files
.git/
.github/
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Environment files (secrets should be injected via K8s secrets/configmaps)
**/.env
**/.env.local
**/.env.*.local

# Local certificates (TLS handled by ingress in K8s)
.cert/

# Test files
**/__tests__/
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
**/coverage/
**/.nyc_output/

# Documentation (not needed in image)
*.md
docs/

# Sample data
sample/
results/

# Python artifacts (legacy)
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Logs
*.log
npm-debug.log*

# Docker
Dockerfile*
docker-compose*
.docker/

# Claude
.claude/

# Integration tests (not needed in image)
integration-tests/
