# Server
PORT=3001
USE_HTTPS=true

# Email (SMTP) — for sending invoice PDFs
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Data Store — 'json' (default) or 'postgres'
DATA_STORE=json
DATABASE_URL=postgresql://localhost:5432/ballroom_comp

# MindBody API — app-level developer key
# Get yours at https://developers.mindbodyonline.com/
MINDBODY_API_KEY=
MINDBODY_SOURCE_NAME=
