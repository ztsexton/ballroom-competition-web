# Server
PORT=3001
USE_HTTPS=true

# Firebase Admin SDK
# Option 1 (recommended for K8s): Paste the entire service account JSON as a single line
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"..."}
#
# Option 2: Path to service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
#
# Option 3: Just the project ID (works on GCP or with gcloud auth locally)
FIREBASE_PROJECT_ID=ballroom-comp-manager

# Email (SMTP) — for sending invoice PDFs
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Data Store — 'json' (default) or 'postgres'
DATA_STORE=json
DATABASE_URL=postgresql://localhost:5432/ballroom_comp

# MindBody API — app-level developer key
# Get yours at https://developers.mindbodyonline.com/
MINDBODY_API_KEY=
MINDBODY_SOURCE_NAME=

# PostgreSQL Configuration
# Copy this file to .env and update the values

# Database credentials (must match docker-compose.yml)
POSTGRES_USER=ballroom
POSTGRES_PASSWORD=ballroom
POSTGRES_DB=ballroom_scorer

# Backend configuration
DATA_STORE=postgres
DATABASE_URL=postgresql://ballroom:ballroom@localhost:5432/ballroom_scorer

# Optional: Set to 'false' to use HTTP instead of HTTPS
# USE_HTTPS=false
