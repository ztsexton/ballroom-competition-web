{
  "name": "ballroom-scorer-backend",
  "version": "1.0.0",
  "description": "Backend API for Ballroom Competition Scoring System",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --require dotenv/config src/server.ts",
    "build": "tsc && cp src/services/data/schema.sql dist/services/data/",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "ballroom",
    "scoring",
    "competition"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/multer": "^2.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "firebase-admin": "^13.6.0",
    "helmet": "^7.1.0",
    "multer": "^2.1.1",
    "nodemailer": "^7.0.13",
    "pdfkit": "^0.17.2",
    "pg": "^8.18.0",
    "pino": "^10.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.11.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/nodemailer": "^7.0.9",
    "@types/pdfkit": "^0.17.4",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.2",
    "dotenv": "^17.2.4",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
